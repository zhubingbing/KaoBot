# PageIndex API Key (get from https://dash.pageindex.ai)
PAGEINDEX_API_KEY=your_pageindex_api_key_here

# LLM Provider (ollama / vllm / deepseek)
KAOBOT_LLM_PROVIDER=ollama
KAOBOT_LLM_BASE_URL=http://localhost:11434/v1
KAOBOT_LLM_MODEL=qwen3:8b
KAOBOT_LLM_API_KEY=ollama

# DeepSeek (备选)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Semantic Scholar API Key (optional, increases rate limit)
# SEMANTIC_SCHOLAR_API_KEY=your_key_here
